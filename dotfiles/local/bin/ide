#!/usr/bin/env bash
# ide — open the 5-pane IDE layout rooted at ~/Development (or a dir you pass).
#
#   ┌─────────────────────────┬──────────────────────┐
#   │ nvim   (pane 1)         │ cheatsheet (pane 2)   │
#   │                         ├──────────────────────┤
#   ├────────────┬────────────┤ agent / claude (.3)  │
#   │ shell (.4) │ shell (.5) │                      │
#   └────────────┴────────────┴──────────────────────┘
#   (right column widened to fit the 4-column cheatsheet)
#
# Usage:   ide                 (root = ~/Development; resumes last Claude session, fresh if none)
#          ide <dir>           (root the IDE at <dir> instead)
#          AGENT_CMD=claude ide          (always a fresh Claude session)
#          AGENT_CMD=opencode ide        (use opencode instead)
set -euo pipefail

dir="${1:-$HOME/Development}"
name="$(basename "$dir" | tr ' .' '__')"
# Default: continue the most recent Claude conversation in this dir, else start fresh.
agent="${AGENT_CMD:-claude --continue 2>/dev/null || claude}"

build() {            # $1 = "session:window" target whose start pane becomes the editor
  local win="$1" wh ww rcols cheat_rows claude_rows ed cs ag sh1
  wh=$(tmux display -p -t "$win" '#{window_height}')
  ww=$(tmux display -p -t "$win" '#{window_width}')

  # Right column wide enough for the 4-column cheatsheet (~185 cols + margin),
  # but never starve the editor — fall back to half-width on a narrow screen.
  rcols=190
  (( ww - rcols < 80 )) && rcols=$(( ww / 2 ))

  # Target panes by their stable pane-id (%N), NOT positional index: tmux
  # renumbers pane indices by position on every split, so ".4" stops meaning
  # what it did one split earlier. Each split returns the new pane's id.
  ed=$(tmux display -p -t "$win" '#{pane_id}')                            # start pane → editor
  tmux send-keys -t "$ed" "nvim" C-m

  cs=$(tmux split-window -h -l "$rcols" -t "$ed" -c "$dir" -PF '#{pane_id}')  # right column top → cheatsheet

  # Split the right column: top stays = cheatsheet, bottom = agent.
  cheat_rows=48
  claude_rows=$(( wh - cheat_rows )); (( claude_rows < 8 )) && claude_rows=$(( wh / 2 ))
  ag=$(tmux split-window -v -l "$claude_rows" -t "$cs" -c "$dir" -PF '#{pane_id}')  # bottom-right → agent

  tmux send-keys -t "$cs" "~/.config/tmux/cheatsheet-pinned.sh" C-m       # pinned cheatsheet
  tmux send-keys -t "$ag" "$agent" C-m                                    # AI agent

  sh1=$(tmux split-window -v -l 25% -t "$ed" -c "$dir" -PF '#{pane_id}')  # bottom-left → shell
  tmux split-window -h -t "$sh1" -c "$dir"                                # second shell beside it
  tmux select-pane -t "$ed"                                              # focus the editor

  # Window name keeps the IDE identity but tracks the focused pane's command,
  # e.g. "IDE (nvim)", "IDE (claude)", "IDE (zsh)". allow-rename off stops apps
  # from clobbering it via title escape sequences.
  tmux set-option -w -t "$win" allow-rename off
  tmux set-option -w -t "$win" automatic-rename on
  tmux set-option -w -t "$win" automatic-rename-format 'IDE (#{pane_current_command})'

  # Remember this geometry so `prefix Space` can restore it later.
  tmux set-option -w -t "$win" @ide_layout "$(tmux display -p -t "$win" '#{window_layout}')"
}

if [ -n "${TMUX:-}" ]; then
  # Already inside tmux: build the layout in a fresh window.
  win="$(tmux new-window -c "$dir" -P -F '#{session_name}:#{window_index}')"
  build "$win"
elif tmux has-session -t "$name" 2>/dev/null; then
  # IDE session already running (e.g. reopening Alacritty after detach/crash):
  # just reattach — don't rebuild or stack a second window.
  tmux attach -t "$name"
else
  # Not in tmux: create the session, then build the layout *after* a client
  # attaches and the window reaches its real size. Building before attach is
  # unreliable — when Alacritty launches us at startup the PTY still reports the
  # default 80x24, so build()'s geometry collapses into a 50/50 split that just
  # scales up. Polling tmux's own window_width (post-attach) is authoritative.
  tmux new-session -d -s "$name" -c "$dir"
  (
    for _ in $(seq 1 100); do                       # wait up to ~5s for real size
      ww=$(tmux display -p -t "$name" '#{window_width}' 2>/dev/null || echo 0)
      (( ww > 100 )) && break
      sleep 0.05
    done
    build "${name}:$(tmux display -p -t "$name" '#{window_index}')"
  ) &
  tmux attach -t "$name"
fi
